# Gemma CogniVault — Environment Configuration
# Copy this file to .env and adjust values for your setup.

# LLM & Embedding (Ollama)
LLM_MODEL=gemma4:e4b
EMBEDDING_MODEL=embeddinggemma
OLLAMA_HOST=http://localhost:11434

# Vector Store paths
INDEX_FILE=vector_store.faiss
METADATA_FILE=vector_store.json
DOCS_DIR=docs
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# Database (DBOS / PostgreSQL)
DB_URL=postgresql://postgres:password@localhost:5432/dbos

# Server
CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]
MAX_UPLOAD_SIZE_MB=50

# Logging
LOG_LEVEL=INFO
